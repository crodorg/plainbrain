# plainbrain home locations — example config.
#
# Copy this to ~/.config/plainbrain/env and `source` it from your shell rc so BOTH the
# session hooks and Claude inherit the paths, e.g. add to ~/.bashrc (or ~/.zshrc):
#
#     [ -f ~/.config/plainbrain/env ] && . ~/.config/plainbrain/env
#
# Unset variables fall back to the ~/... defaults shown, so you only need the lines you
# actually want to relocate. (install.sh offers to place this file and add the source line.)

export PLAINBRAIN_WIKI="$HOME/wiki"          # compiled, interlinked knowledge wiki
export PLAINBRAIN_DATA="$HOME/data"          # raw reference material (read-only sources)
export PLAINBRAIN_PROJECTS="$HOME/projects"  # per-project repos
export PLAINBRAIN_NOTES="$HOME/notes"        # personal notes (a wiki source)
